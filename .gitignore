node_modules/
.npm/
.pnpm-store/
.yarn/

# ==========================================
# Build and generated output (含各个子模块)
# ==========================================
dist/
assets/dist/
build/
out/
target/
.cache/
.vite/
tools/scene-host/desktop/.pack/
tools/scene-host/desktop/dist/
tools/scene-host/desktop/dist-build/
tools/scene-host/desktop/dist-installer/
/tests/fixtures/ai-test/out/

# ==========================================
