# ==========================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
selenium-debug.log

# ==========================================
# Test output
# ==========================================
coverage/
test-results/
playwright-report/

# ==========================================
# Python (Tools & Agents)
# ==========================================
__pycache__/
*.py[cod]
*$py.class
tools/threejson-agent/shell/py/tmp

# ==========================================
# Local environment and machine-specific config
# ==========================================
.env
.env.*
!.env.example
*.local
package-lock.json
setting.json

# 配置文件白名单（允许提交特定编辑器的配置）
!assets/json/other/scene-editor/setting.json
!assets/json/other/scene-player/setting.json

# 明确忽略特定 Agent 模块的本地临时配置
/tools/threejson-agent/setting.json
/tools/mcp-threejson/setting.json

# ==========================================
# Temporary files
# ==========================================
tmp/
temp/