{
  "name": "electron-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c blue,green \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron ./electron/main.mjs\"",
    "build": "vite build",
    "start": "electron ./electron/main.mjs",
    "preview": "vite build && electron ./electron/main.mjs",
    "build:exe": "vite build && electron-builder"
  },
  "dependencies": {
    "@tweenjs/tween.js": "^25.0.0",
    "html2canvas-pro": "^2.0.0",
    "three": "^0.184.0",
    "threejson": "file:../../.."
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^42.0.0",
    "typescript": "~5.6.3",
    "vite": "^6.0.0",
    "wait-on": "^8.0.1"
  }
}
