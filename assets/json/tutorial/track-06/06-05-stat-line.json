{
  "version": "next",
  "name": "tutorial-stat-line",
  "sceneConfig": {
    "scene": { "background": "#101820" },
    "textFont": {
      "preloadCharacters": "Q1Q4AD"
    },
    "camera": {
      "fov": 52,
      "position": { "x": 0, "y": 70, "z": 130 },
