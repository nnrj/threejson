              { "x": 20, "y": 28, "z": -8 },
              { "x": 55, "y": 52, "z": -8, "label": "Q4" }
            ]
          },
          {
            "name": "series-b",
            "color": "#ffb74d",
            "points": [
              { "x": -50, "y": 8, "z": 12, "label": "A" },
              { "x": -15, "y": 22, "z": 12 },
              { "x": 20, "y": 42, "z": 12 },
              { "x": 55, "y": 35, "z": 12, "label": "D" }
