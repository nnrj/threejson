          }
        },
        "slices": [
          { "value": 35, "label": "A", "color": "#42a5f5" },
          { "value": 25, "label": "B", "color": "#66bb6a" },
          { "value": 22, "label": "C", "color": "#ffa726" },
          { "value": 18, "label": "D", "color": "#ef5350" }
        ]
      }
    ]
