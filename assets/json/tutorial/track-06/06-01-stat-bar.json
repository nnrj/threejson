{
  "version": "next",
  "name": "tutorial-stat-bar",
  "sceneConfig": {
    "scene": { "background": "#101820" },
    "camera": {
      "fov": 52,
      "position": { "x": 0, "y": 90, "z": 180 },
      "near": 0.1,
      "far": 4000
