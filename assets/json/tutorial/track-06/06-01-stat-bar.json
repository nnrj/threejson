            "value": 18,
            "max": 100,
            "label": "18%"
          },
          {
            "name": "bar-mid",
            "position": { "x": 0, "y": 0, "z": 0 },
            "value": 55,
            "max": 100
          },
          {
            "name": "bar-high",
            "position": { "x": 50, "y": 0, "z": 0 },
            "value": 92,
            "max": 100
          }
        ]
      }
    ]
  }
}
