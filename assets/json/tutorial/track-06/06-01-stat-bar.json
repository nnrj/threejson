      { "type": "directional", "color": "#ffffff", "intensity": 1.2, "position": { "x": 72, "y": 130, "z": 96 } }
    ],
    "renderLoop": { "autoResize": true, "firstAutoResize": true }
  },
  "worldInfo": {
    "boxModelList": [
      {
        "name": "floor",
