{
  "version": "next",
  "name": "scene-lifecycle-scene-ready-signal",
  "sceneConfig": {
    "scene": { "background": "#1e2838" },
    "textFont": { "preloadCharacters": "场景加载完成" },
    "camera": { "fov": 50, "near": 0.1, "far": 200, "position": { "x": 0, "y": 6, "z": 14 } },
    "renderer": { "antialias": true, "ratioRate": 1 },
    "controls": { "enableDamping": true, "target": { "x": 0, "y": 2, "z": 0 } },
    "lights": [
      { "type": "ambient", "color": "#ffffff", "intensity": 0.9 },
      { "type": "directional", "color": "#ffffff", "intensity": 1.1, "position": { "x": 10, "y": 14, "z": 10 } }
    ],
    "renderLoop": { "autoResize": true, "firstAutoResize": true }
  },
  "objectList": [
    { "threeJsonId": "ready-floor", "objType": "floor", "geometry": { "width": 12, "height": 0.5, "depth": 8 }, "position": { "x": 0, "y": -0.25, "z": 0 }, "material": { "color": "#2d3a4a" } },
    { "threeJsonId": "ready-label", "name": "ready-label", "objType": "text", "content": "场景加载完成 · scene.ready", "mode": "sdf", "fontSize": 1, "color": "#9aa3ad", "align": "center", "billboard": true, "position": { "x": 0, "y": 3, "z": 0 }, "sdf": { "outlineWidth": 0.04, "outlineColor": "#1a2030" } },
    {
      "threeJsonId": "ready-trigger",
      "name": "ready-trigger",
      "objType": "sphere",
      "position": { "x": 0, "y": -3, "z": 0 },
      "geometry": { "radius": 1.2, "widthSegments": 24, "heightSegments": 12 },
      "material": { "type": "standard", "color": "#67c23a" },
      "events": {
        "scene.ready": {
          "script": "await wait(200)\nself.moveBy(0, 4, 0)"
        }
      }
    }
  ],
  "threeJsonId": "scene-lifecycle-scene-ready-signal"
}
