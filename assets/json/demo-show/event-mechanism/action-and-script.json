{
  "version": "next",
  "name": "event-mechanism-action-and-script",
  "sceneConfig": {
    "scene": { "background": "#11151b" },
    "camera": { "fov": 50, "near": 0.1, "far": 200, "position": { "x": 0, "y": 6, "z": 14 } },
    "renderer": { "antialias": true, "ratioRate": 1 },
    "controls": { "enableDamping": true, "target": { "x": 0, "y": 2, "z": 0 } },
    "lights": [
      { "type": "ambient", "color": "#ffffff", "intensity": 1 },
      { "type": "directional", "color": "#ffffff", "intensity": 1.1, "position": { "x": 10, "y": 14, "z": 10 } }
    ],
    "renderLoop": { "autoResize": true, "firstAutoResize": true }
  },
  "objectList": [
    {
      "threeJsonId": "combo-box",
      "objType": "box",
      "position": { "x": -3, "y": 2, "z": 0 },
      "geometry": { "width": 2.6, "height": 2.6, "depth": 2.6 },
      "material": { "type": "standard", "color": "#9c27b0" },
      "events": {
        "object.ready": {
          "action": { "type": "object.moveBy", "delta": { "x": 3, "y": 0, "z": 0 } },
          "script": "await wait(500)\nself.moveBy(0, 2, 0)"
        }
      }
    }
  ],
  "threeJsonId": "event-mechanism-action-and-script"
}
